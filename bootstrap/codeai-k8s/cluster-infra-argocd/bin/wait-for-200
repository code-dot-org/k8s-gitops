#!/usr/bin/env ruby
# frozen_string_literal: true

require "ipaddr"
require "net/http"
require "optparse"
require "openssl"
require "resolv"
require "time"
require "uri"

module WaitFor200
  # Recursive resolvers can cache stale negative answers and stale delegation
  # during NS create/delete churn, which causes long false waits.
  CLOUDFLARE_DNS = "1.1.1.1"
  GOOGLE_DNS = "8.8.8.8"
  PUBLIC_DNS_SERVERS = [CLOUDFLARE_DNS, GOOGLE_DNS].freeze
  NS_TYPE = Resolv::DNS::Resource::IN::NS
  QUERY_TYPES = [
    ["A", Resolv::DNS::Resource::IN::A],
    ["AAAA", Resolv::DNS::Resource::IN::AAAA],
  ].freeze

  class AttemptFailed < StandardError; end

  class DnsClient
    def resources(nameserver:, host:, typeclass:)
      dns = Resolv::DNS.new(nameserver: [nameserver], search: [], ndots: 1)
      dns.getresources(host, typeclass).map do |resource|
        if resource.respond_to?(:address)
          resource.address.to_s
        elsif resource.respond_to?(:name)
          resource.name.to_s.chomp(".")
        else
          raise "unsupported DNS resource: #{resource.inspect}"
        end
      end.compact.uniq
    ensure
      dns&.close
    end
  end

  class HttpClient
    def get(uri:, ip_address:)
      http = Net::HTTP.new(uri.host, uri.port)
      http.ipaddr = ip_address if ip_address
      http.use_ssl = (uri.scheme == "https")
      http.open_timeout = 5
      http.read_timeout = 20
      http.write_timeout = 20 if http.respond_to?(:write_timeout=)
      http.verify_mode = OpenSSL::SSL::VERIFY_PEER

      request = Net::HTTP::Get.new(uri.request_uri)
      http.request(request)
    end
  end

  class Resolver
    def initialize(dns_client: DnsClient.new, public_dns_servers: PUBLIC_DNS_SERVERS)
      @dns_client = dns_client
      @public_dns_servers = public_dns_servers
    end

    def endpoint_ip_addresses(host)
      return [[host], []] if literal_ip_address?(host)

      nameservers, nameserver_errors = authoritative_nameservers(host)
      nameserver_ips, nameserver_ip_errors = authoritative_nameserver_ip_addresses(nameservers)
      authoritative_ips, authoritative_errors = lookup_addresses(
        hosts: [host],
        nameservers: nameserver_ips,
      )
      direct_ips, direct_errors = direct_endpoint_ip_addresses(host)

      ips = (authoritative_ips + direct_ips).uniq

      errors = nameserver_errors + nameserver_ip_errors + authoritative_errors + direct_errors
      errors << "no authoritative endpoint IPs found for #{host}" if ips.empty?

      [ips, errors.uniq]
    end

    private def authoritative_nameservers(host)
      nameservers, errors = merge_results(@public_dns_servers.map do |recursive_nameserver|
        authoritative_nameservers_via_recursive_resolver(host, recursive_nameserver)
      end
      )

      errors << "no authoritative nameservers found for #{host}" if nameservers.empty?
      [nameservers, errors]
    end

    private def authoritative_nameservers_via_recursive_resolver(host, recursive_nameserver)
      errors = []

      suffix_candidates(host).each do |candidate|
        nameservers, query_errors = query_resources(
          nameserver: recursive_nameserver,
          host: candidate,
          typeclass: NS_TYPE,
          label: "#{recursive_nameserver} NS #{candidate}",
        )
        errors.concat(query_errors)
        return [nameservers, errors] unless nameservers.empty?
      end

      [[], errors]
    end

    private def authoritative_nameserver_ip_addresses(nameservers)
      ip_addresses, errors = lookup_addresses(
        hosts: nameservers,
        nameservers: @public_dns_servers,
      )
      ip_addresses = preferred_ip_addresses(ip_addresses)
      errors << "no authoritative nameserver IPs found" if nameservers.any? && ip_addresses.empty?

      [ip_addresses, errors]
    end

    private def direct_endpoint_ip_addresses(host)
      lookup_addresses(
        hosts: [host],
        nameservers: @public_dns_servers,
        label_prefix: "direct ",
      )
    end

    private def query_resources(nameserver:, host:, typeclass:, label:)
      [@dns_client.resources(nameserver: nameserver, host: host, typeclass: typeclass), []]
    rescue StandardError => exception
      [[], ["#{label}: #{exception.class}: #{exception.message}"]]
    end

    private def merge_results(results)
      values = []
      errors = []

      results.each do |item_values, item_errors|
        values.concat(item_values)
        errors.concat(item_errors)
      end

      [values.uniq, errors.uniq]
    end

    # Once candidate authoritative nameservers are known, trust their A/AAAA
    # answers over recursive negative cache during delegation churn.
    private def lookup_addresses(hosts:, nameservers:, label_prefix: nil)
      ip_addresses = []
      errors = []

      nameservers.each do |nameserver|
        hosts.each do |host|
          QUERY_TYPES.each do |label, typeclass|
            query_ip_addresses, query_errors = query_resources(
              nameserver: nameserver,
              host: host,
              typeclass: typeclass,
              label: "#{nameserver} #{label_prefix}#{label} #{host}".squeeze(" "),
            )
            ip_addresses.concat(query_ip_addresses)
            errors.concat(query_errors)
          end
        end
      end

      [ip_addresses.uniq, errors.uniq]
    end

    private def suffix_candidates(host)
      labels = host.chomp(".").split(".")
      return [host] if labels.length < 2

      (0..(labels.length - 2)).map {|index| labels[index..].join(".")}
    end

    # If both families are published for the authoritative nameserver hostnames,
    # prefer IPv4. This workstation often has no IPv6 route to AWS nameservers,
    # and the wait should not be held hostage by unreachable AAAA glue.
    private def preferred_ip_addresses(ip_addresses)
      ipv4_addresses, other_addresses = ip_addresses.partition {|ip_address| IPAddr.new(ip_address).ipv4?}
      return ipv4_addresses unless ipv4_addresses.empty?

      other_addresses
    rescue IPAddr::InvalidAddressError
      ip_addresses
    end

    private def literal_ip_address?(host)
      IPAddr.new(host)
      true
    rescue IPAddr::InvalidAddressError
      false
    end
  end

  class Checker
    def initialize(resolver: Resolver.new, http_client: HttpClient.new)
      @resolver = resolver
      @http_client = http_client
    end

    def fetch(uri, limit = 5)
      raise AttemptFailed, "too many redirects" if limit <= 0

      endpoint_ip_addresses, dns_errors = @resolver.endpoint_ip_addresses(uri.host)
      cycle_errors = dns_errors.dup

      # Try every candidate endpoint IP because propagation and load-balancer
      # readiness can be uneven for a while.
      endpoint_ip_addresses.each do |endpoint_ip_address|
        response = attempt(uri, endpoint_ip_address, limit, cycle_errors)
        return response if response
      end

      raise AttemptFailed, cycle_errors.uniq.join("; ")
    end

    private def attempt(uri, endpoint_ip_address, limit, cycle_errors)
      response = @http_client.get(uri: uri, ip_address: endpoint_ip_address)
      return fetch(uri + response["location"], limit - 1) if redirect_response?(response)
      return response if response.code == "200"

      cycle_errors << "#{endpoint_ip_address}: HTTP #{response.code}"
      nil
    rescue AttemptFailed => exception
      cycle_errors << "#{endpoint_ip_address}: redirect failed: #{exception.message}"
      nil
    rescue StandardError => exception
      cycle_errors << "#{endpoint_ip_address}: #{exception.class}: #{exception.message}"
      nil
    end

    private def redirect_response?(response)
      response.code.to_s.start_with?("3") && response["location"]
    end
  end
end

if __FILE__ == $PROGRAM_NAME
  timeout_seconds = 1200
  poll_every_seconds = 5
  usage = "usage: #{File.basename($PROGRAM_NAME)} [--timeout-seconds <value>] [--poll-every-seconds <value>] <url>"

  parser = OptionParser.new do |opts|
    opts.on("--timeout-seconds VALUE", Integer) {|value| timeout_seconds = value}
    opts.on("--poll-every-seconds VALUE", Integer) {|value| poll_every_seconds = value}
  end

  parser.parse!(ARGV)

  url = ARGV.shift or abort(usage)
  ARGV.empty? or abort(usage)

  uri = URI(url)
  deadline = Time.now + timeout_seconds
  checker = WaitFor200::Checker.new

  loop do
    begin
      checker.fetch(uri)
      puts "[#{Time.now.iso8601}] #{url} returned 200"
      exit 0
    rescue StandardError => exception
      error_message = exception.is_a?(WaitFor200::AttemptFailed) ? exception.message : "#{exception.class}: #{exception.message}"
      puts "[#{Time.now.iso8601}] #{url} failed: #{error_message}"
    end

    abort("#{url} did not return 200 within #{timeout_seconds}s") if Time.now >= deadline

    sleep poll_every_seconds
  end
end
