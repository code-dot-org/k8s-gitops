#!/usr/bin/env -S bundle exec ruby
# frozen_string_literal: true

require "optparse"
require "open3"
require "json"
require "set"
require "shellwords"
require "tmpdir"
require "time"
require "timeout"
require "yaml"
require "action_view"

module ArgoTrace
  extend self
  extend ActionView::Helpers::DateHelper

  TreeNode = Struct.new(:kind, :name, :namespace, :children, :metadata, keyword_init: true)

  DEFAULT_NON_TTY_WRAP_WIDTH = 150
  DEFAULT_PER_CALL_TIMEOUT_SECONDS = 60
  DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS = 90
  DEFAULT_MAX_PARALLEL_CALLS = 50
  DEFAULT_KUBECTL_DETAILS = true
  DEFAULT_REF_MAX_RECURSION_DEPTH = 2
  DEFAULT_MAX_WAVE_3_APPLICATION_RESOURCE_DETAILS = 4
  ARGO_TREE_KINDS = Set.new(%w[Application ApplicationSet]).freeze
  ORDERED_GROUP_KINDS = Set.new(%w[SyncWave RollingSyncStep]).freeze
  FOLLOW_REF_NOISE_KINDS = Set.new(
    %w[
      Certificate
      CertificateValidation
      Policy
      Record
      Role
      RolePolicy
      RolePolicyAttachment
    ]
  ).freeze
  TIMESTAMP_STYLE_BY_FIELD = {
    "deletionTimestamp" => :red,
  }.freeze
  APPSET_GOOD_CONDITION_STATUSES = {
    "ParametersGenerated" => "True",
    "ResourcesUpToDate" => "True",
    "ErrorOccurred" => "False",
    "RolloutProgressing" => "False",
  }.freeze
  WAVE1_APPSET_LIST_COMMAND = ["argocd", "--core", "appset", "list", "-o", "yaml"].freeze
  WAVE1_APP_LIST_COMMAND = ["argocd", "--core", "--app-namespace", "argocd", "app", "list", "-o", "yaml"].freeze
  CommandFailed = Class.new(StandardError)

  def parse_cli_options(argv)
    options = {
      poll_every: nil,
      soft_wrap: :auto,
      kubectl_details: DEFAULT_KUBECTL_DETAILS,
      ref_max_recursion_depth: DEFAULT_REF_MAX_RECURSION_DEPTH,
    }

    OptionParser.new do |parser|
      parser.on("--poll-every DURATION", "Repeat at an interval like 30s, 1m, or 1hr") do |value|
        options[:poll_every] = parse_duration(value)
      end

      parser.on("--soft-wrap WIDTH", Integer, "Soft-wrap tree lines at WIDTH columns") do |value|
        raise OptionParser::InvalidArgument, value.to_s unless value.positive?

        options[:soft_wrap] = value
      end

      parser.on("--no-wrap", "Disable soft-wrapping tree lines") do
        options[:soft_wrap] = nil
      end

      parser.on("--kubectl-details VALUE", "Enable or disable wave-3 kubectl detail fetches (1, 0, true, false)") do |value|
        options[:kubectl_details] = parse_cli_boolean(value, flag_name: "--kubectl-details")
      end

      parser.on("--ref-max-recursion-depth DEPTH", Integer, "Follow owner/ref children this many levels from already-arrowed live resource nodes") do |value|
        raise OptionParser::InvalidArgument, value.to_s if value.negative?

        options[:ref_max_recursion_depth] = value
      end
    end.parse!(argv)

    argv.empty? or raise OptionParser::InvalidOption, argv.first

    options
  end

  def parse_cli_boolean(value, flag_name:)
    normalized = value.to_s.strip.downcase

    return true if %w[1 true].include?(normalized)
    return false if %w[0 false].include?(normalized)

    raise OptionParser::InvalidArgument, "#{flag_name}=#{value}"
  end

  def parse_duration(value)
    stripped = value.to_s.strip
    match = stripped.match(/\A(\d+)(s|m|hr)\z/)
    abort("--poll-every requires a duration like 30s, 1m, or 1hr") unless match

    amount = match[1].to_i
    unit = match[2]
    seconds = {
      "s" => 1,
      "m" => 60,
      "hr" => 3600,
    }.fetch(unit)

    amount * seconds
  end

  def parse_api_group(api_version)
    api_version.to_s.split("/", 2)[1].to_s
  end

  def format_clock_time(time)
    hour = time.hour % 12
    hour = 12 if hour.zero?
    meridiem = time.hour < 12 ? "a" : "p"

    format("%d:%02d%s and %ds", hour, time.min, meridiem, time.sec)
  end

  def format_elapsed(seconds)
    format("%.1fs", seconds)
  end

  def load_argocd_yaml(yaml_text)
    YAML.safe_load(yaml_text, permitted_classes: [Time], aliases: true) || {}
  end

  def argocd_output_list(payload)
    return payload if payload.is_a?(Array)
    return payload.fetch("items") if payload.is_a?(Hash) && payload.key?("items")

    raise TypeError, "expected an Argo list payload"
  end

  def argocd_output_object(payload)
    return payload if payload.is_a?(Hash)

    raise TypeError, "expected an Argo object payload"
  end

  def owner_reference_names(argocd_object, kind:)
    owner_references = argocd_object.dig("metadata", "ownerReferences") || []
    owner_references.
      select {|owner_reference| owner_reference["kind"] == kind}.
      map {|owner_reference| owner_reference["name"]}
  end

  def child_application_names(argocd_app)
    resources = argocd_app.dig("status", "resources") || []
    resources.
      select {|resource| resource["kind"] == "Application"}.
      map {|resource| resource["name"]}
  end

  def build_app_inventory(argocd_apps)
    argocd_apps.each_with_object({}) do |argocd_app, inventory|
      name = argocd_app.dig("metadata", "name")
      next unless name

      inventory[name] = {
        name: name,
        namespace: argocd_app.dig("metadata", "namespace"),
        raw: argocd_app,
        owner_application_names: owner_reference_names(argocd_app, kind: "Application"),
        owner_appset_names: owner_reference_names(argocd_app, kind: "ApplicationSet"),
        child_application_names: child_application_names(argocd_app),
      }
    end
  end

  def build_appset_inventory(argocd_appsets)
    argocd_appsets.each_with_object({}) do |argocd_appset, inventory|
      name = argocd_appset.dig("metadata", "name")
      next unless name

      inventory[name] = {
        name: name,
        namespace: argocd_appset.dig("metadata", "namespace"),
        raw: argocd_appset,
      }
    end
  end

  def build_root_inventory(app_inventory)
    child_application_names = app_inventory.values.each_with_object(Set.new) do |argocd_app, names|
      argocd_app.fetch(:child_application_names).each {|name| names << name}
    end

    root_inventory = app_inventory.values.reject do |argocd_app|
      argocd_app.fetch(:owner_application_names).any? ||
        argocd_app.fetch(:owner_appset_names).any? ||
        child_application_names.include?(argocd_app.fetch(:name))
    end

    root_inventory.sort_by {|argocd_app| argocd_app.fetch(:name)}
  end

  def application_conditions(argocd_app)
    argocd_app.dig(:raw, "status", "conditions") || []
  end

  def status_hash(argocd_object)
    return unless argocd_object.is_a?(Hash)

    status = argocd_object["status"]
    status if status.is_a?(Hash)
  end

  def sync_status(argocd_object)
    status = status_hash(argocd_object)
    return status.dig("sync", "status") if status

    argocd_object["status"]
  end

  def health_status(argocd_object)
    status_hash(argocd_object)&.dig("health", "status") || argocd_object.dig("health", "status")
  end

  def health_message(argocd_object)
    status_hash(argocd_object)&.dig("health", "message") || argocd_object.dig("health", "message")
  end

  def operation_phase(argocd_object)
    status_hash(argocd_object)&.dig("operationState", "phase")
  end

  def operation_message(argocd_object)
    status_hash(argocd_object)&.dig("operationState", "message")
  end

  def appset_conditions(argocd_object)
    Array(status_hash(argocd_object)&.fetch("conditions", nil))
  end

  def non_good_appset_conditions(argocd_object)
    appset_conditions(argocd_object).reject {|condition| good_appset_condition?(condition)}
  end

  def app_sync_status(argocd_app)
    sync_status(argocd_app[:raw])
  end

  def app_health_status(argocd_app)
    health_status(argocd_app[:raw])
  end

  def app_non_idle?(argocd_app)
    app_sync_status(argocd_app) != "Synced" ||
      app_health_status(argocd_app) != "Healthy" ||
      application_conditions(argocd_app).any?
  end

  def app_needed_for_structure?(argocd_app)
    argocd_app.fetch(:child_application_names).any? ||
      argocd_app.fetch(:raw).dig("status", "resources")&.any? {|resource| resource["kind"] == "ApplicationSet"}
  end

  def rollout_frontier_app_names(argocd_appsets)
    argocd_appsets.
      flat_map {|argocd_appset| argocd_appset.dig("status", "applicationStatus") || []}.
      filter_map {|application_status| application_status["application"]}.
      uniq.
      sort
  end

  def appsets_requiring_detail(appset_inventory)
    appset_inventory.keys.sort
  end

  def apps_requiring_detail(app_inventory:, root_inventory:, argocd_appsets:)
    root_names = root_inventory.to_set {|argocd_app| argocd_app.fetch(:name)}
    frontier_names = rollout_frontier_app_names(argocd_appsets).to_set

    argocd_apps_requiring_detail = app_inventory.values.select do |argocd_app|
      root_names.include?(argocd_app.fetch(:name)) ||
        app_needed_for_structure?(argocd_app) ||
        app_non_idle?(argocd_app) ||
        frontier_names.include?(argocd_app.fetch(:name))
    end

    argocd_apps_requiring_detail.map {|argocd_app| argocd_app.fetch(:name)}.sort
  end

  def run_command(command_runner, command, timeout_seconds: nil)
    command_runner.call(*command, timeout_seconds: timeout_seconds)
  rescue ArgumentError => exception
    raise unless exception.message.include?("unknown keyword: :timeout_seconds")

    command_runner.call(*command)
  end

  def fetch_argocd_list(command_runner, command)
    payload = load_argocd_yaml(run_command(command_runner, command))
    argocd_output_list(payload)
  end

  def load_raw_kubeconfig
    stdout, _stderr, status = capture_command(
      "kubectl",
      "config",
      "view",
      "--raw",
      "-o",
      "json",
      timeout_seconds: 5
    )
    raise CommandFailed, "failed to read kubeconfig" unless status.success?

    JSON.parse(stdout)
  end

  def kubeconfig_context(kubeconfig, context_name)
    Array(kubeconfig["contexts"]).find {|context| context["name"] == context_name}
  end

  def shared_argocd_kubeconfig_path(context_name)
    sanitized_context_name = context_name.gsub(/[^A-Za-z0-9_.-]/, "_")
    File.join(Dir.tmpdir, "argo-trace-kubeconfig-#{sanitized_context_name}.yaml")
  end

  def shared_kubeconfig_env
    explicit_context = ENV["ARGOCD_KUBE_CONTEXT"].to_s.strip
    kubeconfig = load_raw_kubeconfig
    current_context = kubeconfig["current-context"].to_s.strip
    return {env: {}, cleanup: nil} if current_context.empty?

    if explicit_context.empty?
      source_context = kubeconfig_context(kubeconfig, current_context)
      return {env: {}, cleanup: nil} unless source_context
      return {env: {}, cleanup: nil} if source_context.dig("context", "namespace") == "argocd"

      rewritten_kubeconfig = kubeconfig.merge(
        "current-context" => current_context,
        "contexts" => Array(kubeconfig["contexts"]).reject {|context| context["name"] == current_context} + [
          source_context.merge(
            "name" => current_context,
            "context" => source_context.fetch("context", {}).merge("namespace" => "argocd")
          )
        ]
      )
      kubeconfig_path = shared_argocd_kubeconfig_path(current_context)
    else
      return {env: {}, cleanup: nil} if current_context == explicit_context
      return {env: {}, cleanup: nil} unless kubeconfig_context(kubeconfig, explicit_context)

      rewritten_kubeconfig = kubeconfig.merge("current-context" => explicit_context)
      kubeconfig_path = shared_argocd_kubeconfig_path(explicit_context)
    end

    File.write(kubeconfig_path, YAML.dump(rewritten_kubeconfig))

    {
      env: {"KUBECONFIG" => kubeconfig_path},
      cleanup: nil,
    }
  rescue StandardError
    {env: {}, cleanup: nil}
  end

  def shell_command_runner
    shared_kubeconfig = nil

    lambda do |*command, timeout_seconds: nil|
      env = {}
      if %w[argocd kubectl].include?(command.first)
        shared_kubeconfig ||= shared_kubeconfig_env
        env = shared_kubeconfig.fetch(:env, {})
      end

      puts "COMMAND START: #{Shellwords.join(command)}"
      stdout, stderr, status = capture_command(*command, env: env, timeout_seconds: timeout_seconds)
      puts "COMMAND RETURN: #{Shellwords.join(command)}"
      puts "STDOUT <<EOF"
      print stdout.to_s
      puts unless stdout.to_s.end_with?("\n")
      puts "EOF"
      puts "STDERR <<EOF"
      print stderr.to_s
      puts unless stderr.to_s.end_with?("\n")
      puts "EOF"
      return stdout if status.success?

      message = stderr.to_s.strip
      message = stdout.to_s.strip if message.empty?
      message = "command failed with exit #{status.exitstatus}" if message.empty?
      raise CommandFailed, "#{command.join(' ')}: #{message}"
    end
  end

  def capture_command(*command, env: {}, timeout_seconds: nil)
    Bundler.with_unbundled_env do
      Open3.popen3(env, *command) do |stdin, stdout, stderr, wait_thr|
        stdin.close

        stdout_reader = Thread.new do
          stdout.read
        rescue IOError
          +""
        end
        stdout_reader.report_on_exception = false

        stderr_reader = Thread.new do
          stderr.read
        rescue IOError
          +""
        end
        stderr_reader.report_on_exception = false

        status =
          if timeout_seconds
            wait_thr.join(timeout_seconds)&.value || timeout_process(wait_thr, stdout, stderr)
          else
            wait_thr.value
          end

        [stdout_reader.value, stderr_reader.value, status]
      ensure
        stdout.close unless stdout.closed?
        stderr.close unless stderr.closed?
        stdout_reader&.join
        stderr_reader&.join
      end
    end
  end

  def timeout_process(wait_thr, stdout, stderr)
    pid = wait_thr.pid
    Process.kill("TERM", pid)
    wait_thr.join(5)&.value || begin
      Process.kill("KILL", pid)
      wait_thr.value
    end
  rescue Errno::ESRCH
    wait_thr.value
  ensure
    stdout.close unless stdout.closed?
    stderr.close unless stderr.closed?
    raise Timeout::Error
  end

  def appset_get_command(name)
    ["argocd", "--core", "appset", "get", name, "-o", "yaml"]
  end

  def app_get_command(name)
    ["argocd", "--core", "--app-namespace", "argocd", "app", "get", name, "-o", "yaml"]
  end

  def fetch_argocd_lists_in_parallel(command_runner, commands)
    threads = commands.map do |name, command|
      Thread.new do
        [name, fetch_argocd_list(command_runner, command)]
      end
    end

    threads.map(&:value).to_h
  end

  def fetch_wave1_app_and_appset_list(command_runner:)
    wave1_app_and_appset_lists = fetch_argocd_lists_in_parallel(
      command_runner,
      appsets: WAVE1_APPSET_LIST_COMMAND,
      apps: WAVE1_APP_LIST_COMMAND
    )
    argocd_appsets = wave1_app_and_appset_lists.fetch(:appsets)
    argocd_apps = wave1_app_and_appset_lists.fetch(:apps)

    app_inventory = build_app_inventory(argocd_apps)
    {
      argocd_apps: argocd_apps,
      argocd_appsets: argocd_appsets,
      app_inventory: app_inventory,
      appset_inventory: build_appset_inventory(argocd_appsets),
      root_inventory: build_root_inventory(app_inventory),
    }
  end

  def wave_2_app_details_jobs(appset_names:, app_names:, app_inventory: {}, appset_inventory: {})
    appset_names.map do |name|
      {
        type: :appset,
        name: name,
        command: appset_get_command(name),
        fallback_raw: appset_inventory[name]&.fetch(:raw, nil),
      }
    end + app_names.map do |name|
      {
        type: :app,
        name: name,
        command: app_get_command(name),
        fallback_raw: app_inventory[name]&.fetch(:raw, nil),
      }
    end
  end

  def success_result(job, raw:)
    {
      type: job.fetch(:type),
      name: job.fetch(:name),
      command: job.fetch(:command),
      raw: raw,
      error: nil,
    }
  end

  def error_result(job, stderr:, error:)
    {
      type: job.fetch(:type),
      name: job.fetch(:name),
      command: job.fetch(:command),
      raw: nil,
      error: {
        command: job.fetch(:command).join(" "),
        stderr: stderr,
        message: error,
      },
    }
  end

  def call_with_timeout(command_runner, job, per_call_timeout_seconds, parser: method(:argocd_output_object))
    yaml_text = run_command(command_runner, job.fetch(:command), timeout_seconds: per_call_timeout_seconds)
    payload = load_argocd_yaml(yaml_text)

    success_result(job, raw: parser.call(payload))
  rescue Timeout::Error
    error_result(
      job,
      stderr: "timed out after #{per_call_timeout_seconds}s",
      error: :timeout
    )
  rescue StandardError => exception
    fallback_raw = job[:fallback_raw]
    return success_result(job, raw: fallback_raw) if fallback_raw

    error_result(
      job,
      stderr: exception.message,
      error: :command_failed
    )
  end

  def timed_out_result(job, total_timeout_seconds)
    error_result(
      job,
      stderr: "total snapshot timeout after #{total_timeout_seconds}s",
      error: :total_timeout
    )
  end

  # Wave 2 and wave 3 have the same execution shape: bounded fanout, per-call
  # timeouts, and a total snapshot deadline that marks unfinished jobs.
  def fetch_jobs_in_parallel(command_runner:, jobs:, result_key:, parser: method(:argocd_output_object), max_parallel_calls: DEFAULT_MAX_PARALLEL_CALLS, per_call_timeout_seconds: DEFAULT_PER_CALL_TIMEOUT_SECONDS, total_snapshot_timeout_seconds: DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS, monotonic_now: -> {Process.clock_gettime(Process::CLOCK_MONOTONIC)})
    return {results: {}, timed_out: false} if jobs.empty?

    queue = Queue.new
    jobs.each {|job| queue << job}

    results = {}
    completed_keys = Set.new
    mutex = Mutex.new
    deadline = monotonic_now.call + total_snapshot_timeout_seconds
    worker_count = [jobs.length, max_parallel_calls].min

    workers = Array.new(worker_count) do
      Thread.new do
        loop do
          break if monotonic_now.call >= deadline

          job = queue.pop(true)
          job_result = call_with_timeout(command_runner, job, per_call_timeout_seconds, parser: parser)
          mutex.synchronize do
            key = result_key.call(job)
            results[key] = job_result
            completed_keys << key
          end
        rescue ThreadError
          break
        end
      end
    end

    workers.each do |worker|
      remaining = deadline - monotonic_now.call
      break if remaining <= 0

      worker.join(remaining)
    end

    timed_out = monotonic_now.call >= deadline
    workers.each(&:kill) if timed_out

    if timed_out
      mutex.synchronize do
        jobs.each do |job|
          key = result_key.call(job)
          next if completed_keys.include?(key)

          results[key] ||= timed_out_result(job, total_snapshot_timeout_seconds)
        end
      end
    end

    {results: results, timed_out: timed_out}
  end

  def fetch_wave_2_app_details(command_runner:, appset_names:, app_names:, app_inventory: {}, appset_inventory: {}, max_parallel_calls: DEFAULT_MAX_PARALLEL_CALLS, per_call_timeout_seconds: DEFAULT_PER_CALL_TIMEOUT_SECONDS, total_snapshot_timeout_seconds: DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS, monotonic_now: -> {Process.clock_gettime(Process::CLOCK_MONOTONIC)})
    jobs = wave_2_app_details_jobs(
      appset_names: appset_names,
      app_names: app_names,
      app_inventory: app_inventory,
      appset_inventory: appset_inventory
    )
    fetch_results = fetch_jobs_in_parallel(
      command_runner: command_runner,
      jobs: jobs,
      result_key: ->(job) {[job.fetch(:type), job.fetch(:name)]},
      max_parallel_calls: max_parallel_calls,
      per_call_timeout_seconds: per_call_timeout_seconds,
      total_snapshot_timeout_seconds: total_snapshot_timeout_seconds,
      monotonic_now: monotonic_now
    )
    results = fetch_results.fetch(:results)

    {
      appsets: appset_names.each_with_object({}) do |name, index|
        index[name] = results[[:appset, name]]
      end,
      apps: app_names.each_with_object({}) do |name, index|
        index[name] = results[[:app, name]]
      end,
      timed_out: fetch_results.fetch(:timed_out),
    }
  end

  def appset_status_by_application(argocd_appset)
    (argocd_appset.dig("status", "applicationStatus") || []).each_with_object({}) do |application_status, index|
      application_name = application_status["application"]
      next unless application_name

      index[application_name] = application_status
    end
  end

  def app_resource_ref(app_resource)
    {
      group: app_resource["group"].to_s,
      kind: app_resource["kind"],
      name: app_resource["name"],
      namespace: app_resource["namespace"],
    }
  end

  def rolling_sync_step_label(step_index, step)
    match_expression = Array(step["matchExpressions"]).first || {}
    values = Array(match_expression["values"])
    expression = [
      match_expression["key"],
      match_expression["operator"],
      "[#{values.join(', ')}]",
    ].compact.join(" ")

    "RollingSync step #{step_index + 1} (#{expression})"
  end

  def duplicate_app_resource_counts(app_resources)
    app_resources.each_with_object(Hash.new(0)) do |app_resource, counts|
      counts[[app_resource["kind"], app_resource["name"]]] += 1
    end
  end

  def app_resource_display_name(app_resource, duplicate_counts)
    name = app_resource["name"]
    return name if duplicate_counts[[app_resource["kind"], name]] == 1

    [name, app_resource["namespace"]].compact.join("/")
  end

  def app_resource_non_good?(app_resource)
    sync = sync_status(app_resource)
    health = health_status(app_resource)

    (sync && sync != "Synced") || (health && health != "Healthy")
  end

  def deleting_argocd_object?(argocd_object)
    !!argocd_object.dig("metadata", "deletionTimestamp")
  end

  def build_app_resource_node(app_resource, duplicate_counts:, app_inventory:, appset_inventory:, app_enrichment:, appset_enrichment:, parent_deleting:)
    display_name = app_resource_display_name(app_resource, duplicate_counts)

    case app_resource["kind"]
    when "ApplicationSet"
      TreeNode.new(
        kind: "ApplicationSet",
        name: display_name,
        namespace: app_resource["namespace"],
        children: [],
        metadata: {
          appset_name: app_resource["name"],
          raw: appset_inventory[app_resource["name"]]&.fetch(:raw, nil),
        }
      )
    when "Application"
      build_application_tree(
        app_resource["name"],
        app_inventory: app_inventory,
        appset_inventory: appset_inventory,
        app_enrichment: app_enrichment,
        appset_enrichment: appset_enrichment,
        parent_deleting: parent_deleting
      ).tap do |node|
        node.name = display_name
      end
    else
      TreeNode.new(
        kind: app_resource["kind"],
        name: display_name,
        namespace: app_resource["namespace"],
        children: [],
        metadata: {
          raw: app_resource,
          argo_resource_ref: app_resource_ref(app_resource),
        }
      )
    end
  end

  def direct_child_resource_nodes(argocd_app, app_inventory:, appset_inventory:, app_enrichment:, appset_enrichment:)
    app_resources = (argocd_app.dig("status", "resources") || []).
      select {|app_resource| app_resource["kind"] == "ApplicationSet"}
    duplicate_counts = duplicate_app_resource_counts(app_resources)
    parent_deleting = deleting_argocd_object?(argocd_app)

    app_resources.map do |app_resource|
      build_app_resource_node(
        app_resource,
        duplicate_counts: duplicate_counts,
        app_inventory: app_inventory,
        appset_inventory: appset_inventory,
        app_enrichment: app_enrichment,
        appset_enrichment: appset_enrichment,
        parent_deleting: parent_deleting
      )
    end
  end

  def sync_wave_key(app_resource)
    app_resource.key?("syncWave") ? app_resource["syncWave"].to_i : 0
  end

  def sync_wave_app_resources(argocd_app)
    (argocd_app.dig("status", "resources") || []).select do |app_resource|
      next false if app_resource["kind"] == "ApplicationSet"
      next true if app_resource["kind"] == "Application"

      app_resource_non_good?(app_resource) && !boring_app_resource_for_live_detail?(app_resource)
    end
  end

  def build_sync_wave_groups(argocd_app, app_inventory:, appset_inventory:, app_enrichment:, appset_enrichment:)
    app_resources = sync_wave_app_resources(argocd_app)
    return [] if app_resources.empty?

    duplicate_counts = duplicate_app_resource_counts(app_resources)
    grouped_resources = app_resources.group_by {|app_resource| sync_wave_key(app_resource)}
    parent_deleting = deleting_argocd_object?(argocd_app)
    grouped_resources.keys.sort.map do |wave|
      wave_app_resources = grouped_resources.fetch(wave).sort_by do |app_resource|
        [
          app_resource["kind"] == "Application" ? 0 : 1,
          app_resource["kind"],
          app_resource["name"],
          app_resource["namespace"].to_s,
        ]
      end

      children = wave_app_resources.map do |app_resource|
        build_app_resource_node(
          app_resource,
          duplicate_counts: duplicate_counts,
          app_inventory: app_inventory,
          appset_inventory: appset_inventory,
          app_enrichment: app_enrichment,
          appset_enrichment: appset_enrichment,
          parent_deleting: parent_deleting
        )
      end

      TreeNode.new(
        kind: "SyncWave",
        name: "sync-wave #{wave}",
        children: children,
        metadata: {}
      )
    end
  end

  def build_appset_tree(appset_name, app_inventory:, appset_inventory:, app_enrichment:, appset_enrichment:, parent_deleting: false)
    enrichment_result = appset_enrichment[appset_name]
    argocd_appset = enrichment_result&.dig(:raw) || appset_inventory[appset_name]&.fetch(:raw, nil) || missing_argocd_object("ApplicationSet", appset_name)
    application_status_by_name = appset_status_by_application(argocd_appset)
    steps = argocd_appset.dig("spec", "strategy", "rollingSync", "steps") || []
    appset_deleting = deleting_argocd_object?(argocd_appset)

    children = if steps.any?
                 steps.each_with_index.map do |step, step_index|
                   step_number = (step_index + 1).to_s
                   step_children = application_status_by_name.values.
                     select {|application_status| application_status["step"] == step_number}.
                     sort_by {|application_status| application_status["application"]}.
                     map do |application_status|
                       build_application_tree(
                         application_status.fetch("application"),
                         app_inventory: app_inventory,
                         appset_inventory: appset_inventory,
                         app_enrichment: app_enrichment,
                         appset_enrichment: appset_enrichment,
                          rollout_status: application_status,
                          parent_deleting: appset_deleting || parent_deleting,
                        )
                     end

                   TreeNode.new(
                     kind: "RollingSyncStep",
                     name: rolling_sync_step_label(step_index, step),
                     children: step_children,
                     metadata: {
                       step: step,
                     }
                   )
                 end
               else
                 app_inventory.values.
                   select {|argocd_app| argocd_app.fetch(:owner_appset_names).include?(appset_name)}.
                   sort_by {|argocd_app| argocd_app.fetch(:name)}.
                   map do |argocd_app|
                     build_application_tree(
                       argocd_app.fetch(:name),
                       app_inventory: app_inventory,
                       appset_inventory: appset_inventory,
                       app_enrichment: app_enrichment,
                       appset_enrichment: appset_enrichment,
                       parent_deleting: appset_deleting || parent_deleting,
                     )
                   end
               end

    TreeNode.new(
      kind: "ApplicationSet",
      name: appset_name,
      namespace: argocd_appset.dig("metadata", "namespace"),
      children: children,
      metadata: {
        raw: argocd_appset,
        enrichment_result: enrichment_result,
        expected_missing: parent_deleting && missing_argocd_object?(argocd_appset),
      }
    )
  end

  def missing_argocd_object(kind, name)
    {
      "apiVersion" => "argoproj.io/v1alpha1",
      "kind" => kind,
      "metadata" => {
        "name" => name,
        "annotations" => {
          "argo-trace/code-object-missing" => "true",
        },
      },
      "status" => {},
    }
  end

  def missing_argocd_object?(argocd_object)
    argocd_object.dig("metadata", "annotations", "argo-trace/code-object-missing") == "true"
  end

  def build_application_tree(app_name, app_inventory:, appset_inventory:, app_enrichment: {}, appset_enrichment: {}, rollout_status: nil, parent_deleting: false)
    enrichment_result = app_enrichment[app_name]
    argocd_app = enrichment_result&.dig(:raw) || app_inventory[app_name]&.fetch(:raw, nil) || missing_argocd_object("Application", app_name)
    sync_wave_groups = build_sync_wave_groups(
      argocd_app,
      app_inventory: app_inventory,
      appset_inventory: appset_inventory,
      app_enrichment: app_enrichment,
      appset_enrichment: appset_enrichment
    )
    direct_children = direct_child_resource_nodes(
      argocd_app,
      app_inventory: app_inventory,
      appset_inventory: appset_inventory,
      app_enrichment: app_enrichment,
      appset_enrichment: appset_enrichment
    )

    appset_children = direct_children.
      select {|node| node.kind == "ApplicationSet"}.
      map do |node|
        build_appset_tree(
          node.metadata.fetch(:appset_name),
          app_inventory: app_inventory,
          appset_inventory: appset_inventory,
          app_enrichment: app_enrichment,
          appset_enrichment: appset_enrichment,
          parent_deleting: deleting_argocd_object?(argocd_app)
        )
      end

    TreeNode.new(
      kind: "Application",
      name: app_name,
      namespace: argocd_app.dig("metadata", "namespace"),
      children: sync_wave_groups + appset_children.sort_by {|node| [node.kind, node.name]},
      metadata: {
        raw: argocd_app,
        enrichment_result: enrichment_result,
        rollout_status: rollout_status,
        expected_missing: parent_deleting && missing_argocd_object?(argocd_app),
      }
    )
  end

  def build_tree(root_inventory:, app_inventory:, appset_inventory:, app_enrichment:, appset_enrichment:)
    root_inventory.map do |root_argocd_app|
      build_application_tree(
        root_argocd_app.fetch(:name),
        app_inventory: app_inventory,
        appset_inventory: appset_inventory,
        app_enrichment: app_enrichment,
        appset_enrichment: appset_enrichment
      )
    end
  end

  def good_appset_condition?(condition)
    expected_status = APPSET_GOOD_CONDITION_STATUSES[condition["type"]]
    return false unless expected_status

    condition["status"] == expected_status
  end

  def node_error_summary(node)
    error = node.metadata.dig(:enrichment_result, :error)
    return nil unless error

    error[:message] == :total_timeout || error[:message] == :timeout ? "timed out" : "error"
  end

  def expected_missing_node?(node)
    node.metadata[:expected_missing]
  end

  def display_sync_health_parts(argocd_object)
    parts = []
    parts << "sync.status=#{sync_status(argocd_object)}" if sync_status(argocd_object)
    parts << "health.status=#{health_status(argocd_object)}" if health_status(argocd_object)
    parts
  end

  def live_resource_bracket_parts(node)
    kubectl_detail = node.metadata[:kubectl_detail]
    return [] unless kubectl_detail
    return ["error"] if kubectl_detail[:error]

    live_resource = kubectl_detail[:raw]
    return [] unless live_resource.is_a?(Hash) && !live_resource.empty?

    interesting_live_resource_conditions(live_resource).filter_map do |condition|
      next unless condition["type"] && condition["status"]

      "status.conditions.#{condition['type']}=#{condition['status']}"
    end
  end

  def display_resource_bracket_parts(node)
    display_sync_health_parts(node.metadata[:raw] || {}) + live_resource_bracket_parts(node)
  end

  def display_application_bracket_parts(node)
    argocd_object = node.metadata[:raw] || {}
    return ["missing"] if missing_argocd_object?(argocd_object)

    parts = display_sync_health_parts(argocd_object)
    phase = operation_phase(argocd_object)
    parts << "status.operationState.phase=#{phase}" if phase && (phase != "Succeeded" || node.children.any?)
    if (rollout_status = node.metadata[:rollout_status])
      parts << "step=#{rollout_status['step']}" if rollout_status["step"]
      parts << "rollout.status=#{rollout_status['status']}" if rollout_status["status"]
    end
    application_conditions(node.metadata).each do |condition|
      parts << "#{condition['type']}=#{condition.fetch('status', 'True')}"
    end
    parts
  end

  def display_applicationset_bracket_parts(node)
    argocd_object = node.metadata[:raw] || {}
    conditions = appset_conditions(argocd_object)
    return ["all conditions good"] if conditions.any? && conditions.all? {|condition| good_appset_condition?(condition)}

    conditions.map {|condition| "#{condition['type']}=#{condition.fetch('status', 'True')}"}
  end

  def display_bracket_parts(node)
    error_summary = node_error_summary(node)
    return [error_summary] if error_summary

    case node.kind
    when "Application"
      display_application_bracket_parts(node)
    when "ApplicationSet"
      display_applicationset_bracket_parts(node)
    else
      display_resource_bracket_parts(node)
    end
  end

  def display_scalar(value)
    return value.utc.iso8601 if value.is_a?(Time)

    value
  end

  def display_label(node)
    return node.name if %w[RollingSyncStep SyncWave].include?(node.kind)

    label = "#{node.name} (#{node.kind})"
    parts = display_bracket_parts(node)
    return label if parts.empty?

    "#{label} [#{parts.join(', ')}]"
  end

  def node_non_good?(node)
    return true if node.metadata.dig(:enrichment_result, :error)
    return true if live_resource_non_good?(node.metadata[:kubectl_detail])

    argocd_object = node.metadata[:raw] || {}
    return false if missing_argocd_object?(argocd_object) && expected_missing_node?(node)
    return true if missing_argocd_object?(argocd_object)

    case node.kind
    when "Application"
      return true if application_conditions(node.metadata).any?
    when "ApplicationSet"
      return true if non_good_appset_conditions(argocd_object).any?
    end

    phase = operation_phase(argocd_object)
    return true if phase && phase != "Succeeded"

    sync = sync_status(argocd_object)
    health = health_status(argocd_object)

    (sync && sync != "Synced") || (health && health != "Healthy")
  end

  def node_attention_rank(node)
    return nil unless node_non_good?(node)

    argocd_object = node.metadata[:raw] || {}
    return 3 if node.metadata.dig(:enrichment_result, :error)
    return 2 if live_resource_non_good?(node.metadata[:kubectl_detail])
    return nil if missing_argocd_object?(argocd_object) && expected_missing_node?(node)
    return 1 if missing_argocd_object?(argocd_object)

    case node.kind
    when "Application"
      return 3 if application_conditions(node.metadata).any?
    when "ApplicationSet"
      return 3 if non_good_appset_conditions(argocd_object).any?
    end

    return 2 if health_message(argocd_object)
    return 1 if health_status(argocd_object) == "Progressing"

    0
  end

  def fully_all_ok_subtree?(node)
    !node_non_good?(node) && node.children.all? {|child| fully_all_ok_subtree?(child)}
  end

  def arrow_node_label?(node, selected:)
    return false unless selected

    rank = node_attention_rank(node)
    [1, 2].include?(rank)
  end

  def arrowed_child_node_ids(children)
    ranked_children = children.filter_map do |child|
      rank = node_attention_rank(child)
      [child.object_id, rank] if rank
    end
    return Set.new if ranked_children.empty?

    highest_rank = ranked_children.map(&:last).max
    ranked_children.each_with_object(Set.new) do |(node_id, rank), arrowed_node_ids|
      arrowed_node_ids << node_id if rank == highest_rank
    end
  end

  def subtree_has_attention?(node)
    !!node_attention_rank(node) || node.children.any? {|child| subtree_has_attention?(child)}
  end

  def focused_ordered_children(children)
    kinds = children.map(&:kind).uniq
    return children unless kinds.length == 1 && ORDERED_GROUP_KINDS.include?(kinds.first)

    active_child = children.find {|child| subtree_has_attention?(child)}
    active_child ? [active_child] : children
  end

  def deepest_arrowed_node_ids(nodes)
    focused_nodes = focused_ordered_children(nodes)
    direct_arrowed = arrowed_child_node_ids(focused_nodes)

    focused_nodes.each_with_object(Set.new) do |node, arrowed_node_ids|
      child_arrowed = deepest_arrowed_node_ids(node.children)
      if child_arrowed.empty?
        arrowed_node_ids << node.object_id if direct_arrowed.include?(node.object_id)
      else
        child_arrowed.each {|node_id| arrowed_node_ids << node_id}
      end
    end
  end

  def wave_3_resource_node?(node)
    node.metadata[:argo_resource_ref].is_a?(Hash)
  end

  def wave_3_resource_key(argo_resource_ref)
    [
      argo_resource_ref[:group].to_s,
      argo_resource_ref[:kind].to_s,
      argo_resource_ref[:namespace].to_s,
      argo_resource_ref[:name].to_s,
    ]
  end

  def live_object_ref(raw_ref, default_namespace:)
    return unless raw_ref.is_a?(Hash)

    kind = raw_ref["kind"]
    name = raw_ref["name"]
    return unless kind && name

    {
      group: parse_api_group(raw_ref["apiVersion"]),
      kind: kind,
      namespace: raw_ref["namespace"] || default_namespace,
      name: name,
    }
  end

  def followable_live_object_refs(live_resource)
    return [] unless live_resource.is_a?(Hash)

    default_namespace = live_resource.dig("metadata", "namespace")
    refs = []
    Array(live_resource.dig("metadata", "ownerReferences")).each do |owner_reference|
      ref = live_object_ref(owner_reference, default_namespace: default_namespace)
      refs << ref if ref
    end
    [
      live_resource.dig("spec", "resourceRef"),
      live_resource.dig("status", "resourceRef"),
      live_resource.dig("spec", "crossplane", "resourceRef"),
    ].each do |raw_ref|
      ref = live_object_ref(raw_ref, default_namespace: default_namespace)
      refs << ref if ref
    end
    [
      live_resource.dig("spec", "resourceRefs"),
      live_resource.dig("status", "resourceRefs"),
      live_resource.dig("spec", "crossplane", "resourceRefs"),
    ].each do |raw_refs|
      Array(raw_refs).each do |raw_ref|
        ref = live_object_ref(raw_ref, default_namespace: default_namespace)
        refs << ref if ref
      end
    end

    seen_ref_keys = Set.new
    deduped_refs = refs.each_with_object([]) do |ref, memo|
      ref_key = wave_3_resource_key(ref)
      next if seen_ref_keys.include?(ref_key)

      seen_ref_keys << ref_key
      memo << ref
    end

    non_boring_refs = deduped_refs.reject {|ref| boring_follow_ref?(ref)}
    non_boring_refs
  end

  def boring_follow_ref?(argo_resource_ref)
    FOLLOW_REF_NOISE_KINDS.include?(argo_resource_ref[:kind].to_s)
  end

  def collect_selected_wave_3_resource_nodes(nodes, arrowed_node_ids: deepest_arrowed_node_ids(nodes))
    Array(nodes).flat_map do |node|
      selected_nodes = []
      selected_nodes << node if arrowed_node_ids.include?(node.object_id) && wave_3_resource_node?(node)
      selected_nodes.concat(
        collect_selected_wave_3_resource_nodes(
          node.children,
          arrowed_node_ids: deepest_arrowed_node_ids(node.children)
        )
      )
      selected_nodes
    end
  end

  def selected_wave_3_resource_nodes(nodes)
    seen_resource_keys = Set.new

    collect_selected_wave_3_resource_nodes(nodes).each_with_object([]) do |node, selected_nodes|
      resource_key = wave_3_resource_key(node.metadata.fetch(:argo_resource_ref))
      next if seen_resource_keys.include?(resource_key)

      seen_resource_keys << resource_key
      selected_nodes << node
    end
  end

  def flatten_tree_nodes(nodes)
    Array(nodes).flat_map {|node| [node, *flatten_tree_nodes(node.children)]}
  end

  def selected_wave_3_application_nodes(nodes)
    nodes_by_id = flatten_tree_nodes(nodes).to_h {|node| [node.object_id, node]}
    selected_nodes = deepest_arrowed_node_ids(nodes).filter_map do |node_id|
      node = nodes_by_id[node_id]
      next unless node&.kind == "Application"
      next unless (node.metadata[:raw].dig("status", "resources") || []).any? {|app_resource| !ARGO_TREE_KINDS.include?(app_resource["kind"])}
      priority = application_node_live_detail_priority(node)
      next unless priority.positive?

      [priority, node]
    end

    selected_nodes.sort_by do |priority, node|
      [-priority, node.name]
    end.map(&:last)
  end

  def application_node_live_detail_priority(node)
    argocd_object = node.metadata[:raw] || {}
    return 0 if missing_argocd_object?(argocd_object)
    return 0 if health_status(argocd_object) == "Missing"
    return 0 if application_conditions(node.metadata).empty? &&
      sync_status(argocd_object) == "Synced" &&
      health_status(argocd_object) == "Healthy" &&
      [nil, "Succeeded"].include?(operation_phase(argocd_object))

    return 100 if application_conditions(node.metadata).any?
    return 90 if health_message(argocd_object) && health_status(argocd_object) != "Healthy"
    return 80 if operation_phase(argocd_object) && operation_phase(argocd_object) != "Succeeded"
    return 70 if operation_message(argocd_object) && !operation_message(argocd_object).match?(/\Asuccessfully synced\b/i)
    return 70 if %w[Progressing Degraded Suspended Unknown].include?(health_status(argocd_object))
    return 20 if sync_status(argocd_object) && sync_status(argocd_object) != "Synced"

    0
  end

  def kubectl_get_command(argo_resource_ref)
    command = ["kubectl", "get", argo_resource_ref.fetch(:kind), argo_resource_ref.fetch(:name)]
    namespace = argo_resource_ref[:namespace]
    command.push("-n", namespace) if namespace && !namespace.empty?
    command.push("-o", "yaml", "--ignore-not-found")
  end

  def wave_3_kubectl_detail_jobs(resource_nodes)
    resource_nodes.map do |node|
      argo_resource_ref = node.metadata.fetch(:argo_resource_ref)
      {
        type: :resource,
        name: wave_3_resource_key(argo_resource_ref).join("/"),
        resource_key: wave_3_resource_key(argo_resource_ref),
        command: kubectl_get_command(argo_resource_ref),
      }
    end
  end

  def wave_3_application_resource_detail_jobs(application_nodes)
    jobs = application_nodes.flat_map do |node|
      argocd_app = node.metadata[:raw] || {}
      app_name = node.name
      (argocd_app.dig("status", "resources") || []).filter_map do |app_resource|
        next if ARGO_TREE_KINDS.include?(app_resource["kind"])
        priority = app_resource_live_detail_priority(app_resource)
        next unless priority.positive?

        resource_key = [app_name, *wave_3_resource_key(app_resource_ref(app_resource))]
        {
          type: :application_resource,
          name: resource_key.join("/"),
          resource_key: resource_key,
          parent_app_name: app_name,
          app_resource: app_resource,
          command: kubectl_get_command(app_resource_ref(app_resource)),
          priority: priority,
        }
      end
    end

    jobs = jobs.sort_by do |job|
      [
        -job.fetch(:priority),
        job.fetch(:parent_app_name),
        job.fetch(:app_resource).fetch("kind", ""),
        job.fetch(:app_resource).fetch("name", ""),
      ]
    end

    jobs.first(DEFAULT_MAX_WAVE_3_APPLICATION_RESOURCE_DETAILS).map do |job|
      job.reject {|key, _value| key == :priority}
    end
  end

  def app_resource_candidate_for_live_detail?(app_resource)
    app_resource_live_detail_priority(app_resource).positive?
  end

  def boring_app_resource_for_live_detail?(app_resource)
    sync_status = app_resource["status"].to_s
    health_status = app_resource.dig("health", "status").to_s
    health_message = app_resource.dig("health", "message").to_s

    return true if sync_status == "Synced" && health_status == "Healthy"
    return true if sync_status != "Synced" && health_status == "Missing" && health_message.empty?
    return true if health_message == "CRD is healthy"

    false
  end

  def app_resource_live_detail_priority(app_resource)
    sync_status = app_resource["status"].to_s
    health_status = app_resource.dig("health", "status").to_s
    health_message = app_resource.dig("health", "message").to_s
    return 0 if boring_app_resource_for_live_detail?(app_resource)

    score = 0

    # Keep this state-driven. Do not boost by kind name, CRD group, or project-
    # specific prefixes. If a resource deserves follow-up, that decision should
    # come from its visible state, conditions, or messages, not from branding.
    score += 100 unless health_message.empty?
    score += 80 if %w[Progressing Degraded Suspended Unknown].include?(health_status)

    if !sync_status.empty? && sync_status != "Synced" && !health_status.empty? && health_status != "Missing"
      score += 20
    end

    score
  end

  def fetch_wave_3_kubectl_details(command_runner:, resource_nodes:, max_parallel_calls: DEFAULT_MAX_PARALLEL_CALLS, per_call_timeout_seconds: DEFAULT_PER_CALL_TIMEOUT_SECONDS, total_snapshot_timeout_seconds: DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS, monotonic_now: -> {Process.clock_gettime(Process::CLOCK_MONOTONIC)})
    jobs = wave_3_kubectl_detail_jobs(resource_nodes)
    fetch_jobs_in_parallel(
      command_runner: command_runner,
      jobs: jobs,
      result_key: ->(job) {job.fetch(:resource_key)},
      parser: ->(payload) {payload},
      max_parallel_calls: max_parallel_calls,
      per_call_timeout_seconds: per_call_timeout_seconds,
      total_snapshot_timeout_seconds: total_snapshot_timeout_seconds,
      monotonic_now: monotonic_now
    ).fetch(:results)
  end

  def fetch_wave_3_application_resource_details(command_runner:, application_nodes:, max_parallel_calls: DEFAULT_MAX_PARALLEL_CALLS, per_call_timeout_seconds: DEFAULT_PER_CALL_TIMEOUT_SECONDS, total_snapshot_timeout_seconds: DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS, monotonic_now: -> {Process.clock_gettime(Process::CLOCK_MONOTONIC)})
    jobs = wave_3_application_resource_detail_jobs(application_nodes)
    fetch_jobs_in_parallel(
      command_runner: command_runner,
      jobs: jobs,
      result_key: ->(job) {job.fetch(:resource_key)},
      parser: ->(payload) {payload},
      max_parallel_calls: max_parallel_calls,
      per_call_timeout_seconds: per_call_timeout_seconds,
      total_snapshot_timeout_seconds: total_snapshot_timeout_seconds,
      monotonic_now: monotonic_now
    ).fetch(:results)
  end

  def selected_wave_4_ref_root_nodes(nodes)
    nodes_by_id = flatten_tree_nodes(nodes).to_h {|node| [node.object_id, node]}

    deepest_arrowed_node_ids(nodes).filter_map do |node_id|
      node = nodes_by_id[node_id]
      next unless node&.metadata&.dig(:kubectl_detail, :raw).is_a?(Hash)
      next if live_resource_has_blocker_message?(node.metadata[:kubectl_detail])
      next if followable_live_object_refs(node.metadata.dig(:kubectl_detail, :raw)).empty?

      node
    end
  end

  def wave_4_ref_follow_jobs(refs)
    refs.map do |argo_resource_ref|
      {
        type: :follow_ref,
        name: wave_3_resource_key(argo_resource_ref).join("/"),
        resource_key: wave_3_resource_key(argo_resource_ref),
        command: kubectl_get_command(argo_resource_ref),
      }
    end
  end

  def fetch_wave_4_follow_refs(command_runner:, refs:, max_parallel_calls: DEFAULT_MAX_PARALLEL_CALLS, per_call_timeout_seconds: DEFAULT_PER_CALL_TIMEOUT_SECONDS, total_snapshot_timeout_seconds: DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS, monotonic_now: -> {Process.clock_gettime(Process::CLOCK_MONOTONIC)})
    jobs = wave_4_ref_follow_jobs(refs)
    fetch_jobs_in_parallel(
      command_runner: command_runner,
      jobs: jobs,
      result_key: ->(job) {job.fetch(:resource_key)},
      parser: ->(payload) {payload},
      max_parallel_calls: max_parallel_calls,
      per_call_timeout_seconds: per_call_timeout_seconds,
      total_snapshot_timeout_seconds: total_snapshot_timeout_seconds,
      monotonic_now: monotonic_now
    ).fetch(:results)
  end

  def attach_wave_3_details!(nodes, details_by_resource_key)
    Array(nodes).each do |node|
      if (argo_resource_ref = node.metadata[:argo_resource_ref])
        node.metadata[:kubectl_detail] = details_by_resource_key[wave_3_resource_key(argo_resource_ref)]
      end

      attach_wave_3_details!(node.children, details_by_resource_key)
    end
  end

  def live_resource_non_good?(kubectl_detail)
    return false unless kubectl_detail
    return true if kubectl_detail[:error]

    live_resource = kubectl_detail[:raw]
    return false unless live_resource.is_a?(Hash) && !live_resource.empty?

    return true if live_resource.dig("metadata", "deletionTimestamp")
    return true if interesting_live_resource_conditions(live_resource).any?

    status = status_hash(live_resource)
    status && (status["reason"] || status["message"])
  end

  def live_resource_has_blocker_message?(kubectl_detail)
    return false unless kubectl_detail
    return true if kubectl_detail[:error]

    live_resource = kubectl_detail[:raw]
    return false unless live_resource.is_a?(Hash) && !live_resource.empty?

    status = status_hash(live_resource)
    return true if status && status["reason"] && status["message"]

    interesting_live_resource_conditions(live_resource).any? do |condition|
      condition["status"] != "True" && condition["message"]
    end
  end

  def ensure_sync_wave_group!(application_node, wave)
    group_name = "sync-wave #{wave}"
    existing_group = application_node.children.find {|child| child.kind == "SyncWave" && child.name == group_name}
    return existing_group if existing_group

    new_group = TreeNode.new(kind: "SyncWave", name: group_name, children: [], metadata: {})
    application_node.children << new_group
    application_node.children.sort_by! do |child|
      if child.kind == "SyncWave"
        [0, child.name.sub("sync-wave ", "").to_i]
      else
        [1, child.kind, child.name]
      end
    end
    new_group
  end

  def attach_wave_3_application_resource_children!(nodes, details_by_resource_key)
    flatten_tree_nodes(nodes).each do |node|
      next unless node.kind == "Application"

      argocd_app = node.metadata[:raw] || {}
      app_resources = (argocd_app.dig("status", "resources") || []).reject {|app_resource| ARGO_TREE_KINDS.include?(app_resource["kind"])}
      next if app_resources.empty?

      app_resources.each do |app_resource|
        resource_key = [node.name, *wave_3_resource_key(app_resource_ref(app_resource))]
        kubectl_detail = details_by_resource_key[resource_key]
        next unless kubectl_detail && live_resource_non_good?(kubectl_detail)

        sync_wave_group = ensure_sync_wave_group!(node, sync_wave_key(app_resource))
        argo_resource_key = wave_3_resource_key(app_resource_ref(app_resource))
        next if sync_wave_group.children.any? {|child| child.metadata[:argo_resource_ref] && wave_3_resource_key(child.metadata[:argo_resource_ref]) == argo_resource_key}

        sync_wave_group.children << TreeNode.new(
          kind: app_resource["kind"],
          name: app_resource_display_name(app_resource, duplicate_app_resource_counts([app_resource])),
          namespace: app_resource["namespace"],
          children: [],
          metadata: {
            raw: app_resource,
            argo_resource_ref: app_resource_ref(app_resource),
            kubectl_detail: kubectl_detail,
          }
        )
        sync_wave_group.children.sort_by! do |child|
          [
            child.kind == "Application" ? 0 : 1,
            child.kind,
            child.name,
            child.namespace.to_s,
          ]
        end
      end
    end
  end

  def build_live_ref_tree_node(argo_resource_ref, kubectl_detail)
    live_resource = kubectl_detail[:raw]
    TreeNode.new(
      kind: live_resource["kind"] || argo_resource_ref[:kind],
      name: live_resource.dig("metadata", "name") || argo_resource_ref[:name],
      namespace: live_resource.dig("metadata", "namespace") || argo_resource_ref[:namespace],
      children: [],
      metadata: {
        raw: live_resource.is_a?(Hash) ? live_resource : {},
        argo_resource_ref: argo_resource_ref,
        kubectl_detail: kubectl_detail,
      }
    )
  end

  def attach_wave_4_follow_refs!(nodes, command_runner:, ref_max_recursion_depth:, max_parallel_calls: DEFAULT_MAX_PARALLEL_CALLS, per_call_timeout_seconds: DEFAULT_PER_CALL_TIMEOUT_SECONDS, total_snapshot_timeout_seconds: DEFAULT_TOTAL_SNAPSHOT_TIMEOUT_SECONDS, monotonic_now: -> {Process.clock_gettime(Process::CLOCK_MONOTONIC)})
    return if ref_max_recursion_depth <= 0

    frontier_nodes = selected_wave_4_ref_root_nodes(nodes)
    seen_ref_keys = frontier_nodes.each_with_object(Set.new) do |node, keys|
      argo_resource_ref = node.metadata[:argo_resource_ref]
      keys << wave_3_resource_key(argo_resource_ref) if argo_resource_ref
    end
    remaining_depth = ref_max_recursion_depth

    while remaining_depth.positive? && frontier_nodes.any?
      refs_by_parent_node = frontier_nodes.to_h do |node|
        live_resource = node.metadata.dig(:kubectl_detail, :raw)
        refs = followable_live_object_refs(live_resource).reject do |argo_resource_ref|
          seen_ref_keys.include?(wave_3_resource_key(argo_resource_ref))
        end
        refs.each {|argo_resource_ref| seen_ref_keys << wave_3_resource_key(argo_resource_ref)}
        [node, refs]
      end

      refs = refs_by_parent_node.values.flatten(1)
      break if refs.empty?

      details_by_resource_key = fetch_wave_4_follow_refs(
        command_runner: command_runner,
        refs: refs,
        max_parallel_calls: max_parallel_calls,
        per_call_timeout_seconds: per_call_timeout_seconds,
        total_snapshot_timeout_seconds: total_snapshot_timeout_seconds,
        monotonic_now: monotonic_now
      )

      next_frontier_nodes = []
      refs_by_parent_node.each do |node, parent_refs|
        parent_refs.each do |argo_resource_ref|
          kubectl_detail = details_by_resource_key[wave_3_resource_key(argo_resource_ref)]
          next unless kubectl_detail

          child_node = build_live_ref_tree_node(argo_resource_ref, kubectl_detail)
          node.children << child_node
          next if live_resource_has_blocker_message?(kubectl_detail)
          next_frontier_nodes << child_node if followable_live_object_refs(kubectl_detail[:raw]).any?
        end
        node.children.sort_by! {|child| [child.kind.to_s, child.name.to_s, child.namespace.to_s]}
      end

      frontier_nodes = next_frontier_nodes
      remaining_depth -= 1
    end
  end

  def interesting_live_resource_conditions(live_resource)
    Array(status_hash(live_resource)&.fetch("conditions", nil)).
      select do |condition|
        condition["status"] != "True" || condition["message"]
      end.
      first(3)
  end

  def live_resource_detail_entries(node)
    kubectl_detail = node.metadata[:kubectl_detail]
    return [] unless kubectl_detail

    if (error = kubectl_detail[:error])
      return [
        [:line, "kubectl.command: #{error[:command]}", true],
        [:line, "kubectl.stderr: #{error[:stderr]}", true],
      ]
    end

    live_resource = kubectl_detail[:raw]
    return [] unless live_resource.is_a?(Hash) && !live_resource.empty?

    raw_metadata = live_resource["metadata"] || {}
    entries = []
    entries << metadata_timestamp_entry("creationTimestamp", raw_metadata["creationTimestamp"]) if raw_metadata["creationTimestamp"]
    entries << metadata_timestamp_entry("deletionTimestamp", raw_metadata["deletionTimestamp"]) if raw_metadata["deletionTimestamp"]
    entries << [:line, "metadata.finalizers: #{Array(raw_metadata['finalizers']).inspect}", false] if raw_metadata["finalizers"]

    status = status_hash(live_resource)
    entries << [:line, "status.phase: #{status['phase']}", false] if status&.key?("phase")
    entries << [:line, "status.reason: #{status['reason']}", false] if status&.key?("reason")
    entries << [:line, "status.message: #{status['message']}", true] if status&.key?("message")
    interesting_live_resource_conditions(live_resource).each do |condition|
      summary = []
      summary << "status=#{condition['status']}" if condition["status"]
      summary << "reason=#{condition['reason']}" if condition["reason"]
      summary << "message=#{condition['message']}" if condition["message"]
      next if summary.empty?

      entries << [:line, "status.conditions.#{condition.fetch('type', 'condition')}: #{summary.join(', ')}", true]
    end
    entries
  end

  def metadata_detail_entries(argocd_object)
    metadata = argocd_object["metadata"] || {}
    entries = []
    entries << metadata_timestamp_entry("creationTimestamp", metadata["creationTimestamp"]) if metadata["creationTimestamp"]
    entries << metadata_timestamp_entry("deletionTimestamp", metadata["deletionTimestamp"]) if metadata["deletionTimestamp"]
    entries << [:line, "metadata.finalizers: #{Array(metadata['finalizers']).inspect}", false] if metadata["finalizers"]
    entries
  end

  def metadata_timestamp_entry(field_name, raw_timestamp)
    style = TIMESTAMP_STYLE_BY_FIELD[field_name]
    [:line, "metadata.#{field_name}: #{display_metadata_timestamp(raw_timestamp)}", false, style ? {color: style} : nil]
  end

  def display_metadata_timestamp(raw_timestamp, now: Time.now)
    timestamp = Time.parse(raw_timestamp.to_s)
    "#{relative_time_ago(timestamp, now: now)} (#{format_american_datetime(timestamp)})"
  rescue ArgumentError
    display_scalar(raw_timestamp)
  end

  def relative_time_ago(timestamp, now: Time.now)
    seconds_ago = [(now - timestamp).round, 0].max
    return "#{seconds_ago} #{seconds_ago == 1 ? 'second' : 'seconds'} ago" if seconds_ago < 60

    "#{distance_of_time_in_words(timestamp, now)} ago"
  end

  def format_american_datetime(timestamp)
    timestamp.getlocal.strftime("%-m/%-d/%Y %-I:%M:%S %p %Z")
  end

  def condition_detail_entries(condition)
    style_override =
      if condition["type"] == "RolloutProgressing"
        {intensity: :normal}
      end

    arrow = condition["type"] != "RolloutProgressing"

    entries = [[:condition_header, "status.conditions.#{condition['type']}", arrow, style_override]]
    entries << [:condition_detail, "status: #{condition['status']}", false, style_override] if condition["status"]
    entries << [:condition_detail, "reason: #{condition['reason']}", false, style_override] if condition["reason"]
    entries << [:condition_detail, "message: #{condition['message']}", arrow, style_override] if condition["message"]
    entries
  end

  def display_detail_entries(node)
    if node.metadata.dig(:enrichment_result, :error)
      return [
        [:line, "argo_trace.command: #{node.metadata.dig(:enrichment_result, :error, :command)}", true],
        [:line, "argo_trace.stderr: #{node.metadata.dig(:enrichment_result, :error, :stderr)}", true],
      ]
    end

    # A fully healthy rendered subtree should stay glanceable: keep the
    # structure, suppress the bookkeeping.
    return [] if fully_all_ok_subtree?(node)

    argocd_object = node.metadata[:raw] || {}
    entries = []
    entries.concat(metadata_detail_entries(argocd_object)) if %w[Application ApplicationSet].include?(node.kind)
    if (rollout_status = node.metadata[:rollout_status])
      entries << [:line, "status.applicationStatus.lastTransitionTime: #{display_scalar(rollout_status['lastTransitionTime'])}", false] if rollout_status["lastTransitionTime"]
      entries << [:line, "status.applicationStatus.message: #{rollout_status['message']}", false] if rollout_status["message"]
    end
    case node.kind
    when "Application"
      application_conditions(node.metadata).each {|condition| entries.concat(condition_detail_entries(condition))}
    when "ApplicationSet"
      non_good_appset_conditions(argocd_object).each {|condition| entries.concat(condition_detail_entries(condition))}
    end
    if (message = operation_message(argocd_object)) && operation_phase(argocd_object) && operation_phase(argocd_object) != "Succeeded"
      entries << [:line, "status.operationState.message: #{message}", node_non_good?(node)]
    end
    if (message = health_message(argocd_object)) && node_non_good?(node)
      entries << [:health_message, "health.message: #{message}", node_non_good?(node)]
    end
    entries.concat(live_resource_detail_entries(node))
    entries
  end

  def collect_display_lines(nodes, indent: 0, arrowed_node_ids: Set.new, selected_ancestor: false)
    Array(nodes).flat_map do |node|
      highlighted = node_non_good?(node)
      selected = arrowed_node_ids.include?(node.object_id)
      ancestor_of_selected = !selected && subtree_contains_arrowed_node?(node, arrowed_node_ids)
      selected_subtree = selected_ancestor || selected
      node_style = merge_line_style(
        if selected_subtree
          :bold
        elsif ancestor_of_selected
          :normal
        else
          :faint
        end
      )
      lines = [[indent, display_label(node), highlighted, arrow_node_label?(node, selected: selected), :node, node_style]]
      display_detail_entries(node).each do |entry_type, text, arrow, style_override|
        # Condition/error nodes keep their arrows on the attached detail lines,
        # while Progressing/health.message frontiers arrow the resource/app label.
        detail_arrow = arrow && (selected || (!selected_ancestor && arrowed_node_ids.empty?))
        detail_style = merge_line_style(selected_subtree ? :bold : :faint, style_override)
        lines << case entry_type
                 when :condition_header
                   [indent + 1, text, highlighted, detail_arrow, :detail, detail_style]
                 when :condition_detail
                   [indent + 2, text, highlighted, detail_arrow, :detail, detail_style]
                 when :health_message
                   [indent + 1, text, highlighted, detail_arrow, :node, detail_style]
                 else
                   [indent + 1, text, highlighted, detail_arrow, :detail, detail_style]
                 end
      end
      child_arrowed_node_ids =
        if arrowed_node_ids.empty?
          Set.new
        elsif ORDERED_GROUP_KINDS.include?(node.kind) && !subtree_contains_arrowed_node?(node, arrowed_node_ids)
          Set.new
        else
          deepest_arrowed_node_ids(node.children)
        end

      lines.concat(
        collect_display_lines(
          node.children,
          indent: indent + 1,
          arrowed_node_ids: child_arrowed_node_ids,
          selected_ancestor: selected_subtree
        )
      )
      lines
    end
  end

  def subtree_contains_arrowed_node?(node, arrowed_node_ids)
    node.children.any? do |child|
      arrowed_node_ids.include?(child.object_id) || subtree_contains_arrowed_node?(child, arrowed_node_ids)
    end
  end

  def merge_line_style(intensity, style_override = nil)
    {
      intensity: style_override&.fetch(:intensity, intensity) || intensity,
      color: style_override&.fetch(:color, nil),
    }
  end

  # ANSI is emitted as standalone block markers so the visible lines stay easy
  # to diff against the expected fixture and `watch --color` output.
  def render_ansi_display_lines(nodes)
    styled_lines = collect_display_lines(nodes, arrowed_node_ids: deepest_arrowed_node_ids(nodes)).map do |indent, text, _highlighted, arrow, _line_kind, style|
      normal_prefix = "#{'  ' * indent}- "
      rendered_line = if arrow
                        arrow_prefix = "→#{' ' * [((indent * 2) - 1), 1].max}- "
                        "#{arrow_prefix}#{text}"
                      else
                        "#{normal_prefix}#{text}"
                      end
      [style, rendered_line]
    end

    styled_lines.map do |style, rendered_line|
      apply_line_style(rendered_line, style)
    end
  end

  def apply_line_style(rendered_line, style)
    start_code, end_code = ansi_codes_for_style(style)
    return rendered_line if start_code.empty? && end_code.empty?

    "#{start_code}#{rendered_line}#{end_code}"
  end

  def ansi_codes_for_style(style)
    return ["", ""] unless style.is_a?(Hash)

    start_codes = []
    end_codes = []

    case style[:intensity]
    when :bold
      start_codes << 1
      end_codes << 22
    when :faint
      start_codes << 2
      end_codes << 22
    end

    case style[:color]
    when :red
      start_codes << 31
      end_codes.unshift(39)
    when :green
      start_codes << 32
      end_codes.unshift(39)
    end

    [start_codes.empty? ? "" : "\e[#{start_codes.join(';')}m", end_codes.empty? ? "" : "\e[#{end_codes.join(';')}m"]
  end

  def ansi_control_line?(line)
    line.match?(/\A\e\[[0-9;]+m\z/)
  end

  def strip_ansi_codes(line)
    line.gsub(/\e\[[0-9;]+m/, "")
  end

  def ansi_leading_codes(line)
    line[/\A(?:\e\[[0-9;]+m)*/].to_s
  end

  def ansi_trailing_codes(line)
    line[/(?:\e\[[0-9;]+m)*\z/].to_s
  end

  def wrap_chunk(text, width)
    return [text, nil] if text.length <= width

    segment = text[0, width + 1]
    break_at = segment.rindex(" ")
    if break_at&.positive?
      [text[0...break_at], text[(break_at + 1)..].sub(/\A +/, "")]
    else
      [text[0, width], text[width..]]
    end
  end

  def wrap_prefix_and_text(line)
    match = line.match(/\A(→?\s*-\s)(.*)\z/)
    return [match[1], match[2]] if match

    leading_space = line[/\A\s*/]
    [leading_space, line[leading_space.length..]]
  end

  def soft_wrap_line(line, wrap_width)
    return [line] if wrap_width.nil? || ansi_control_line?(line)

    leading_codes = ansi_leading_codes(line)
    trailing_codes = ansi_trailing_codes(line)
    visible_line = line[leading_codes.length...(line.length - trailing_codes.length)]
    visible_line = "" if visible_line.nil?
    return [line] if visible_line.length <= wrap_width

    prefix, text = wrap_prefix_and_text(visible_line)
    return [line] if text.nil? || text.empty?

    continuation_prefix = " " * prefix.length
    wrapped_lines = []
    remaining = text
    current_prefix = prefix
    current_width = [wrap_width - prefix.length, 1].max

    loop do
      chunk, rest = wrap_chunk(remaining, current_width)
      wrapped_lines << "#{current_prefix}#{chunk}"
      break unless rest

      remaining = rest
      current_prefix = continuation_prefix
      current_width = [wrap_width - continuation_prefix.length, 1].max
    end

    wrapped_lines[0] = "#{leading_codes}#{wrapped_lines[0]}" unless wrapped_lines.empty?
    wrapped_lines[-1] = "#{wrapped_lines[-1]}#{trailing_codes}" unless wrapped_lines.empty?
    wrapped_lines
  end

  def soft_wrap_rendered_lines(lines, wrap_width:)
    Array(lines).flat_map {|line| soft_wrap_line(line, wrap_width)}
  end

  def render_display_lines(nodes, wrap_width: nil)
    soft_wrap_rendered_lines(render_ansi_display_lines(nodes), wrap_width: wrap_width).
      reject {|line| ansi_control_line?(line)}.
      map {|line| strip_ansi_codes(line)}
  end

  def render_fixture_snapshot(tree_lines:, start_time:, end_time:, elapsed_seconds:)
    [
      "starting argo-trace @ #{format_clock_time(start_time)}",
      "",
      "# ArgoCD dependency tree @ #{format_clock_time(end_time)}, argo-trace took #{format_elapsed(elapsed_seconds)}",
      "",
      *tree_lines,
    ].join("\n") + "\n"
  end

  def wrap_width_for_snapshot(options, output:)
    return options[:soft_wrap] unless options[:soft_wrap] == :auto
    return DEFAULT_NON_TTY_WRAP_WIDTH unless output.tty?

    output.winsize[1]
  rescue StandardError
    DEFAULT_NON_TTY_WRAP_WIDTH
  end

  def render_snapshot(start_time:, end_time:, elapsed_seconds:, body_text:)
    start_clock_time = format_clock_time(start_time)
    end_clock_time = format_clock_time(end_time)
    elapsed = format_elapsed(elapsed_seconds)

    [
      "starting argo-trace @ #{start_clock_time}",
      "",
      "# ArgoCD dependency tree @ #{end_clock_time}, argo-trace took #{elapsed}",
      "",
      body_text,
    ].join("\n").sub(/\n+\z/, "") + "\n\n\n"
  end

  def snapshot_body(command_runner:, wrap_width:, kubectl_details: DEFAULT_KUBECTL_DETAILS, ref_max_recursion_depth: DEFAULT_REF_MAX_RECURSION_DEPTH)
    inventory = fetch_wave1_app_and_appset_list(command_runner: command_runner)
    app_names = apps_requiring_detail(
      app_inventory: inventory.fetch(:app_inventory),
      root_inventory: inventory.fetch(:root_inventory),
      argocd_appsets: inventory.fetch(:argocd_appsets)
    )
    appset_names = appsets_requiring_detail(inventory.fetch(:appset_inventory))
    enrichment = fetch_wave_2_app_details(
      command_runner: command_runner,
      appset_names: appset_names,
      app_names: app_names,
      app_inventory: inventory.fetch(:app_inventory),
      appset_inventory: inventory.fetch(:appset_inventory)
    )
    tree = build_tree(
      root_inventory: inventory.fetch(:root_inventory),
      app_inventory: inventory.fetch(:app_inventory),
      appset_inventory: inventory.fetch(:appset_inventory),
      app_enrichment: enrichment.fetch(:apps),
      appset_enrichment: enrichment.fetch(:appsets)
    )

    if kubectl_details
      selected_resource_nodes = selected_wave_3_resource_nodes(tree)
      selected_application_nodes = selected_wave_3_application_nodes(tree)
      unless selected_resource_nodes.empty?
        attach_wave_3_details!(
          tree,
          fetch_wave_3_kubectl_details(
            command_runner: command_runner,
            resource_nodes: selected_resource_nodes
          )
        )
      end
      unless selected_application_nodes.empty?
        attach_wave_3_application_resource_children!(
          tree,
          fetch_wave_3_application_resource_details(
            command_runner: command_runner,
            application_nodes: selected_application_nodes
          )
        )
      end
      attach_wave_4_follow_refs!(
        tree,
        command_runner: command_runner,
        ref_max_recursion_depth: ref_max_recursion_depth
      )
    end

    soft_wrap_rendered_lines(render_ansi_display_lines(tree), wrap_width: wrap_width).join("\n")
  end

  def run(options, output: $stdout, now: -> {Time.now}, sleep_proc: ->(seconds) {sleep(seconds)}, body: nil, command_runner: shell_command_runner, max_snapshots: nil)
    snapshot_count = 0
    body ||= lambda do |wrap_width:|
      snapshot_body(
        command_runner: command_runner,
        wrap_width: wrap_width,
        kubectl_details: options.fetch(:kubectl_details, DEFAULT_KUBECTL_DETAILS),
        ref_max_recursion_depth: options.fetch(:ref_max_recursion_depth, DEFAULT_REF_MAX_RECURSION_DEPTH)
      )
    end

    loop do
      start_time = now.call
      wrap_width = wrap_width_for_snapshot(options, output: output)
      body_text = body.call(wrap_width: wrap_width)
      end_time = now.call
      output.write(
        render_snapshot(
          start_time: start_time,
          end_time: end_time,
          elapsed_seconds: end_time - start_time,
          body_text: body_text
        )
      )
      output.flush

      snapshot_count += 1
      break if options[:poll_every].nil?
      break if max_snapshots && snapshot_count >= max_snapshots

      sleep_proc.call(options[:poll_every])
    end
  end
end

if __FILE__ == $PROGRAM_NAME
  ArgoTrace.run(ArgoTrace.parse_cli_options(ARGV))
end
